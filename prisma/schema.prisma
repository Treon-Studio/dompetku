generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model subscriptions {
  id           String   @id @default(uuid())
  name         String
  notes        String?
  url          String
  price        String   @default("0")
  paid         String
  notify       Boolean  @default(false)
  date         String
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
  user_id      String
  active       Boolean? @default(true)
  cancelled_at String?
  nameHash     String?
  user         users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model expenses {
  id         String   @id @default(uuid())
  name       String
  notes      String?
  price      String   @default("0")
  paid_via   String   @default("")
  category   String
  date       String
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  user_id    String
  nameHash   String?
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model income {
  id         String   @id @default(uuid())
  name       String
  notes      String?
  price      String   @default("0")
  category   String
  date       String
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  user_id    String
  nameHash   String?
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model investments {
  id         String   @id @default(uuid())
  name       String
  notes      String?
  price      String   @default("0")
  units      String   @default("0")
  category   String
  date       String
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  user_id    String
  nameHash   String?
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model users {
  id                         String            @id @default(uuid())
  email                      String?
  phone                      String?
  password                   String
  created_at                 DateTime          @default(now())
  updated_at                 DateTime          @default(now()) @updatedAt
  currency                   String            @default("INR")
  locale                     String            @default("en")
  order_identifier           String?
  order_store_id             String?
  order_number               String?
  order_status               String?
  billing_start_date         String?
  plan_status                String            @default("basic")
  trial_start_date           DateTime          @default(now())
  usage                      Int               @default(0)
  basic_usage_limit_email    Boolean           @default(false)
  new_signup_email           Boolean           @default(false)
  premium_plan_expired_email Boolean           @default(false)
  premium_usage_limit_email  Boolean           @default(false)
  monthly_email_report       Boolean           @default(false)
  expenses                   expenses[]
  income                     income[]
  investments                investments[]
  subscriptions              subscriptions[]
  sessions                   sessions[]
  password_resets            password_resets[]
  friends                    friends[]
  debts                      debts[]
  budgets                    budgets[]
  goals                      goals[]
  role                       String            @default("USER") // "USER" or "ADMIN"

  @@unique([email])
  @@unique([phone])
}

model feedbacks {
  id         Int      @id @default(autoincrement())
  message    String
  created_at DateTime @default(now())
  user_id    String
}

model contact {
  id         Int      @id @default(autoincrement())
  message    String
  subject    String
  email      String
  created_at DateTime @default(now())
}

model sessions {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model password_resets {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model friends {
  id         String   @id @default(uuid())
  name       String
  user_id    String
  slug       String   @unique // Pengganti public_token
  is_public  Boolean  @default(true) // Untuk toggle public/private
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  debts      debts[]

  @@unique([user_id, name])
}

model debts {
  id         String   @id @default(uuid())
  name       String
  type       String // "I_OWE" (Saya Ngutang) atau "OWES_ME" (Teman Ngutang)
  amount     String   @default("0")
  status     String   @default("UNPAID") // "UNPAID", "PAID"
  date       String
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  friend_id  String
  user_id    String
  nameHash   String?
  friend     friends  @relation(fields: [friend_id], references: [id], onDelete: Cascade)
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model budgets {
  id         String   @id @default(uuid())
  category   String
  amount     String   @default("0")
  month      String // Format: "YYYY-MM"
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  user_id    String
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, category, month])
}

model goals {
  id             String   @id @default(uuid())
  name           String
  target_amount  String   @default("0")
  current_amount String   @default("0")
  deadline       String?
  status         String   @default("IN_PROGRESS") // "IN_PROGRESS", "ACHIEVED"
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt
  user_id        String
  user           users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model app_settings {
  key            String    @id
  value          String
  description    String?
  updated_at     DateTime  @default(now()) @updatedAt
}
